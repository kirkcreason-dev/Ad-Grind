rules_version = '2';

// Ad Grind — Firestore security rules
// Deploy with:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // Each player can read/write ONLY their own user doc.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Create: only your own doc.
      allow create: if request.auth != null
                    && request.auth.uid == uid;

      // Update: only your own doc. Block obvious tampering by capping
      // how far points/counters can jump in a single write. (Points have
      // no cash value, so this is light-touch. When the prize module goes
      // live, move point-crediting to a Cloud Function and tighten these.)
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.points is int
                    && request.resource.data.points >= 0
                    && request.resource.data.lifetimePoints >= resource.data.lifetimePoints
                    && request.resource.data.dailyAdsWatched <= 200;  // hard ceiling vs scripted spam

      allow delete: if false; // never delete user docs from the client
    }

    // ---- Rewards catalog ----
    // The catalog (physical-goods reward definitions) is read-only to
    // clients — edit it from the console or a function, never the app.
    match /catalog/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Redemptions are recorded on the user doc for now. For launch, move
    // redemption to a Cloud Function so points can't be faked client-side,
    // and write fulfillment records here (server-side only) that your admin
    // console reads to ship orders and mark them shipped.
    match /redemptions/{redemptionId} {
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;
      allow write: if false; // server-side (Cloud Function) only
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
